# Database configuration
# Option 1: Set DB_TYPE explicitly
# Supported values: postgresql, sqlite, mysql, supabase, neon
# If not set, it is auto-detected from DATABASE_URL prefix
# DB_TYPE=postgresql

# Option 2: Set the connection URL (type is auto-detected)
# PostgreSQL (also works for Supabase, Neon):
DATABASE_URL=postgresql://user:password@host:5432/dbname

# SQLite (local file):
# DATABASE_URL=sqlite://./data.db

# MySQL:
# DATABASE_URL=mysql://user:password@host:3306/dbname

# LibSQL/Turso:
# DATABASE_URL=libsql://your-db.turso.io
